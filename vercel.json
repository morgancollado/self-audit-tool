{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "comment": "CSP is set per-request by middleware.ts (it carries the nonce); do NOT add a static Content-Security-Policy here for the dynamic build or it will conflict. These are the non-nonce security headers.",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(), camera=(), microphone=()" }
      ]
    }
  ]
}
